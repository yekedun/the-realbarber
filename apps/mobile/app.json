{
  "expo": {
    "name": "Berber",
    "slug": "berber-randevu",
    "version": "1.0.0",
    "scheme": "berberapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.berberapp",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.berberapp"
        ]
      }
    },
    "android": {
      "package": "com.berberapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "./modules/widget/plugin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "25ac450c-8b07-4703-805f-3d4fea1b8db7"
      }
    },
    "owner": "yekedun"
  }
}
